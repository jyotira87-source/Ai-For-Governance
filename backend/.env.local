# PolisAI Backend Configuration
# Local Development Environment

# Database Configuration (using SQLite for local dev)
# For PostgreSQL: postgresql://user:password@localhost:5432/polisai_db
DATABASE_URL=sqlite:///./polisai.db

# JWT and Security
# IMPORTANT: Change this to a random 32+ character string in production
SECRET_KEY=your-super-secret-key-change-this-in-production-at-least-32-chars

# API Keys
GROQ_API_KEY=your-groq-api-key-here

# Server Configuration
API_PORT=8000
API_HOST=0.0.0.0
